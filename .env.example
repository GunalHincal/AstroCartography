# Astroline ortam değişkenleri — bu dosyayı .env olarak kopyalayıp doldurun.
# cp .env.example .env   (Windows: copy .env.example .env)

# Anthropic Claude API anahtarı (SADECE sunucu tarafında kullanılır)
# https://console.anthropic.com → Settings → API Keys → Create Key
# Anahtar "sk-ant-..." ile başlar.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Maps / Places / TimeZone API anahtarı
# Google Cloud Console'da HTTP referrer + API kısıtlaması eklemeniz ÖNERİLİR.
GOOGLE_PLACES_API_KEY=your_google_places_key
